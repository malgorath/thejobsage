##
## JobSage — Docker Compose environment
## Used by the docker-compose stack. Copy to .env, or reference via
## env_file in docker-compose.yml. All service hostnames use Docker names.
##

APP_NAME="JobSage"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:7500

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (MySQL — Docker service "db") ───────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=resume_builder
DB_USERNAME=laravel
DB_PASSWORD=secret

# ─── Session & Cache (Redis — Docker service "redis") ────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis

# ─── Queue (Redis — processed by jobsage-queue container) ────────────────────
# The jobsage-queue container runs: php artisan queue:work --sleep=3 --tries=3
# All three candidate notification mailables (CandidateConfirmationMail,
# CandidateRejectedMail, PositionFilledMail) are ShouldQueue — this must match.
QUEUE_CONNECTION=redis
# Number of seconds before a queued job is retried if it hasn't completed
QUEUE_RETRY_AFTER=90

# ─── Redis (Docker service "redis") ──────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
# MAIL_MAILER=log writes emails to storage/logs — use during development.
# For Mailtrap sandbox testing use smtp + sandbox.smtp.mailtrap.io on port 2525.
# For production configure SES, Mailgun, or Postmark and change the driver.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@jobsage.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Ollama AI (required) ─────────────────────────────────────────────────────
# host.docker.internal resolves to the host machine — Ollama must be running
# on the host (not inside Docker). If Ollama is containerised, point to its
# container name instead of host.docker.internal.
OLLAMA_API_URL=http://host.docker.internal:11434/api/generate
OLLAMA_LLM_MODEL=llama3.2
# HTTP timeout in seconds; increase for slow / CPU-only hosts
OLLAMA_TIMEOUT=120

# ─── Demo mode ────────────────────────────────────────────────────────────────
# Uncomment to seed a full demo dataset: php artisan db:seed
# APP_ENV=demo
