##
## JobSage — Blind HR Screening Platform
## Copy to .env and fill in values for your environment.
##

APP_NAME="JobSage"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for quick local dev — no server required)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL / MariaDB (recommended for production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=jobsage
# DB_USERNAME=root
# DB_PASSWORD=

# ─── Session & Cache ──────────────────────────────────────────────────────────
# Use "database" for SQLite setups; switch to "redis" when Redis is available
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database

# ─── Queue ────────────────────────────────────────────────────────────────────
# Candidate notification emails (confirmation, rejection, position-filled) are
# queued — a running worker is required in production.
# Run: php artisan queue:work --sleep=3 --tries=3
# Use "database" for simple setups; "redis" for production throughput.
QUEUE_CONNECTION=database

# ─── Redis (optional — improves session / cache / queue performance) ──────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
# "log" captures emails in storage/logs — ideal for local development.
# Mailtrap sandbox: MAIL_MAILER=smtp, HOST=sandbox.smtp.mailtrap.io, PORT=2525
# Production: configure SES, Mailgun, or Postmark and set the driver accordingly.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
# Mailtrap sandbox port; change to 587 / 465 for real SMTP
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# "null" disables TLS; use "tls" or "ssl" in production
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@jobsage.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AI backend (required) ────────────────────────────────────────────────────
# OLLAMA_API_TYPE controls the wire format used for AI requests.
#
#   ollama  (default) — Ollama native format, POST /api/generate
#                       Set OLLAMA_API_URL to e.g. http://localhost:11434/api/generate
#
#   openai            — OpenAI-compatible format, POST /v1/chat/completions
#                       Compatible with: llama.cpp --server, LM Studio, vLLM,
#                       LocalAI, and Ollama's own /v1 endpoint.
#                       Set OLLAMA_API_URL to e.g. http://localhost:8080/v1/chat/completions
#
OLLAMA_API_TYPE=ollama
OLLAMA_API_URL=http://localhost:11434/api/generate
# Model name passed in every request (must be loaded in your server)
OLLAMA_LLM_MODEL=llama3.2
# HTTP timeout in seconds; PII stripping can take 30–120 s on CPU-only hosts
OLLAMA_TIMEOUT=120

# ─── Demo mode ────────────────────────────────────────────────────────────────
# Set APP_ENV=demo to activate DemoSeeder when running: php artisan db:seed
# APP_ENV=demo
